<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidManifest.xml
  Package: com.hawkar6.myfavoriteplaces
  Includes permissions + Google Maps API key placeholder.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.hawkar6.myfavoriteplaces">

    <!-- Permissions (requested at runtime as needed) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyFavoritePlaces"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">

        <!-- Google Maps API Key (replace with your real key) -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="YOUR_GOOGLE_MAPS_API_KEY_HERE" />

        <activity android:name=".MapActivity" />
        <activity android:name=".AddPlaceActivity" />
        <activity android:name=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>
</manifest>